// How many tickets to seed into historical_tickets (for RAG context)
const SEED_COUNT = parseInt(process.env.SEED_COUNT || '100', 10);

// ─── CSV Parser ──────────────────────────────────
function parseCSV(text) {
  const lines = [];
  let current = '';
  let inQuotes = false;

  for (let i = 0; i < text.length; i++) {
